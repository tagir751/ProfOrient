<%- include('../layout', {title: 'Дашборд'}) %>

<div class="max-w-7xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-[var(--ocean-dark)] mb-8">Мой прогресс</h1>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Сессий</p>
                    <p class="text-5xl font-bold text-[var(--ocean-blue)]"><%= sessions.length %></p>
                </div>
                <div class="text-6xl">💬</div>
            </div>
        </div>
        
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Активных действий</p>
                    <p class="text-5xl font-bold text-[var(--turquoise)]"><%= actions.length %></p>
                </div>
                <div class="text-6xl">✅</div>
            </div>
        </div>
        
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Проектов</p>
                    <p class="text-5xl font-bold text-green-600"><%= projects.length %></p>
                </div>
                <div class="text-6xl">📁</div>
            </div>
        </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="glass-panel p-6">
            <h2 class="text-2xl font-bold text-[var(--ocean-dark)] mb-4">Последние сессии</h2>
            <% if (sessions.length === 0) { %>
            <p class="text-gray-600">Нет сессий. <a href="/student/sessions" class="text-[var(--ocean-blue)] underline">Добавить первую</a></p>
            <% } else { %>
            <ul class="space-y-3">
                <% sessions.forEach(s => { %>
                <li class="border-b pb-2">
                    <p class="font-semibold"><%= s.topic || 'Без темы' %></p>
                    <p class="text-gray-600 text-sm"><%= new Date(s.session_date).toLocaleDateString('ru-RU') %></p>
                </li>
                <% }) %>
            </ul>
            <% } %>
        </div>
        
        <div class="glass-panel p-6">
            <h2 class="text-2xl font-bold text-[var(--ocean-dark)] mb-4">Активные действия</h2>
            <% if (actions.length === 0) { %>
            <p class="text-gray-600">Нет активных действий. <a href="/student/actions" class="text-[var(--ocean-blue)] underline">Добавить</a></p>
            <% } else { %>
            <ul class="space-y-3">
                <% actions.forEach(a => { %>
                <li class="border-b pb-2">
                    <p class="font-semibold"><%= a.description %></p>
                    <% if (a.project_name) { %><p class="text-gray-600 text-sm">📁 <%= a.project_name %></p><% } %>
                </li>
                <% }) %>
            </ul>
            <% } %>
        </div>
    </div>
</div>
