<%- include('../layout', {title: 'Мои проекты'}) %>
<div class="max-w-5xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-[var(--ocean-dark)] mb-8">Мои проекты</h1>
    <div class="glass-panel overflow-hidden">
        <% if (projects.length === 0) { %>
        <p class="p-8 text-center text-gray-600 text-xl">Нет проектов</p>
        <% } else { %>
        <table class="w-full">
            <thead class="bg-[var(--ocean-blue)] text-white"><tr><th class="p-4 text-left text-xl">Название</th><th class="p-4 text-left text-xl">Описание</th><th class="p-4 text-left text-xl">Участники</th></tr></thead>
            <tbody>
                <% projects.forEach(p => { %>
                <tr class="border-b hover:bg-gray-50">
                    <td class="p-4 text-large font-semibold"><%= p.name %></td>
                    <td class="p-4 text-large"><%= p.description || '-' %></td>
                    <td class="p-4 text-large"><%= p.member_names || '-' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>
