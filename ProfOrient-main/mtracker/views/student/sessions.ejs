<%- include('../layout', {title: 'Мои сессии'}) %>

<div class="max-w-5xl mx-auto p-6">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-4xl font-bold text-[var(--ocean-dark)]">Мои сессии</h1>
        <button onclick="openModal('sessionModal')" class="btn-ocean px-8 py-4 rounded-lg text-xl font-semibold">
            ➕ Добавить сессию
        </button>
    </div>
    
    <div class="glass-panel overflow-hidden">
        <% if (sessions.length === 0) { %>
        <p class="p-8 text-center text-gray-600 text-xl">Нет сессий. Добавьте первую!</p>
        <% } else { %>
        <table class="w-full">
            <thead class="bg-[var(--ocean-blue)] text-white">
                <tr>
                    <th class="p-4 text-left text-xl">Дата</th>
                    <th class="p-4 text-left text-xl">Тема</th>
                    <th class="p-4 text-left text-xl">Заметки</th>
                </tr>
            </thead>
            <tbody>
                <% sessions.forEach(s => { %>
                <tr class="border-b hover:bg-gray-50">
                    <td class="p-4 text-large"><%= new Date(s.session_date).toLocaleDateString('ru-RU') %></td>
                    <td class="p-4 text-large font-semibold"><%= s.topic || '-' %></td>
                    <td class="p-4 text-large"><%= s.notes || '-' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>

<!-- Модальное окно -->
<div id="sessionModal" class="modal-overlay hidden">
    <div class="glass-panel p-8 max-w-2xl w-full modal-content">
        <h2 class="text-3xl font-bold text-[var(--ocean-dark)] mb-6">Добавить сессию</h2>
        <form action="/student/sessions" method="POST" class="space-y-4">
            <div>
                <label class="block text-xl font-semibold text-gray-700 mb-2">Дата *</label>
                <input type="date" name="session_date" required class="input-large w-full border-2 border-gray-300 rounded-lg p-4">
            </div>
            <div>
                <label class="block text-xl font-semibold text-gray-700 mb-2">Тема</label>
                <input type="text" name="topic" class="input-large w-full border-2 border-gray-300 rounded-lg p-4" placeholder="О чём была сессия?">
            </div>
            <div>
                <label class="block text-xl font-semibold text-gray-700 mb-2">Заметки</label>
                <textarea name="notes" rows="4" class="input-large w-full border-2 border-gray-300 rounded-lg p-4" placeholder="Ваши заметки..."></textarea>
            </div>
            <div class="flex gap-4">
                <button type="submit" class="btn-ocean flex-1 py-4 rounded-lg text-xl font-semibold">Сохранить</button>
                <button type="button" onclick="closeModal('sessionModal')" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-6 py-4 rounded-lg text-xl font-semibold">Отмена</button>
            </div>
        </form>
    </div>
</div>
