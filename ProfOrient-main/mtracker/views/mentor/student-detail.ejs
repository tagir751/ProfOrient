<%- include('../layout', {title: student.full_name || student.login}) %>

<div class="max-w-7xl mx-auto p-6">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-4xl font-bold text-[var(--ocean-dark)]"><%= student.full_name || student.login %></h1>
            <p class="text-xl text-gray-600">@<%= student.login %></p>
        </div>
        <div class="flex gap-4">
            <a href="/mentor/students/<%= student.id %>/edit" class="bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-3 rounded-lg text-xl font-semibold transition">
                ✏️ Редактировать
            </a>
            <a href="/api/export/student/<%= student.id %>/html" target="_blank" class="btn-ocean px-6 py-3 rounded-lg text-xl font-semibold transition">
                📄 Карточка для печати
            </a>
        </div>
    </div>
    
    <!-- Вкладки -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <!-- Сессии -->
        <div class="glass-panel p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-[var(--ocean-dark)]">Последние сессии</h2>
                <span class="text-3xl">💬</span>
            </div>
            
            <% if (sessions.length === 0) { %>
            <p class="text-gray-600 text-lg">Нет сессий</p>
            <% } else { %>
            <div class="space-y-3">
                <% sessions.forEach(session => { %>
                <div class="border-b pb-3 last:border-0">
                    <p class="text-lg font-semibold"><%= session.topic || 'Без темы' %></p>
                    <p class="text-gray-600"><%= new Date(session.session_date).toLocaleDateString('ru-RU') %></p>
                    <% if (session.notes) { %>
                    <p class="text-gray-700 mt-2 text-large"><%= session.notes %></p>
                    <% } %>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>
        
        <!-- Действия -->
        <div class="glass-panel p-6">
            <div class="flex justify-between items-center mb-4">
                <h2 class="text-2xl font-bold text-[var(--ocean-dark)]">Последние действия</h2>
                <span class="text-3xl">✅</span>
            </div>
            
            <% if (actions.length === 0) { %>
            <p class="text-gray-600 text-lg">Нет действий</p>
            <% } else { %>
            <div class="space-y-3">
                <% actions.forEach(action => { %>
                <div class="border-b pb-3 last:border-0">
                    <div class="flex justify-between items-start">
                        <p class="text-lg font-semibold flex-1"><%= action.description %></p>
                        <span class="px-3 py-1 rounded-full text-sm font-semibold ml-2
                            <%= action.status === 'completed' ? 'bg-green-100 text-green-700' : 
                                action.status === 'in_progress' ? 'bg-blue-100 text-blue-700' :
                                action.status === 'cancelled' ? 'bg-red-100 text-red-700' :
                                'bg-yellow-100 text-yellow-700' %>">
                            <%= action.status === 'completed' ? '✓ Готово' : 
                                action.status === 'in_progress' ? 'В работе' :
                                action.status === 'cancelled' ? 'Отменено' :
                                'Ожидает' %>
                        </span>
                    </div>
                    <% if (action.project_name) { %>
                    <p class="text-gray-600 text-sm mt-1">📁 <%= action.project_name %></p>
                    <% } %>
                </div>
                <% }) %>
            </div>
            <% } %>
        </div>
    </div>
    
    <!-- Метрики и графики -->
    <div class="glass-panel p-6 mb-8">
        <h2 class="text-3xl font-bold text-[var(--ocean-dark)] mb-6">Добавить метрики</h2>
        
        <form action="/mentor/students/<%= student.id %>/metrics" method="POST" class="space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label class="block text-xl font-semibold text-gray-700 mb-2">Самостоятельность (%)</label>
                    <input 
                        type="number" 
                        name="independence_score" 
                        min="0" 
                        max="100" 
                        required
                        class="input-large w-full border-2 border-gray-300 rounded-lg p-4"
                        placeholder="0-100"
                    >
                </div>
                
                <div>
                    <label class="block text-xl font-semibold text-gray-700 mb-2">Глубина мышления (%)</label>
                    <input 
                        type="number" 
                        name="thinking_depth_score" 
                        min="0" 
                        max="100" 
                        required
                        class="input-large w-full border-2 border-gray-300 rounded-lg p-4"
                        placeholder="0-100"
                    >
                </div>
                
                <div>
                    <label class="block text-xl font-semibold text-gray-700 mb-2">Доведение до результата (%)</label>
                    <input 
                        type="number" 
                        name="completion_rate" 
                        min="0" 
                        max="100" 
                        required
                        class="input-large w-full border-2 border-gray-300 rounded-lg p-4"
                        placeholder="0-100"
                    >
                </div>
            </div>
            
            <div>
                <label class="block text-xl font-semibold text-gray-700 mb-2">Комментарий</label>
                <textarea 
                    name="notes" 
                    rows="3"
                    class="input-large w-full border-2 border-gray-300 rounded-lg p-4"
                    placeholder="Ваши наблюдения и рекомендации..."
                ></textarea>
            </div>
            
            <button type="submit" class="btn-ocean px-8 py-4 rounded-lg text-xl font-semibold">
                Сохранить метрики
            </button>
        </form>
    </div>
    
    <!-- История метрик -->
    <div class="glass-panel p-6">
        <h2 class="text-3xl font-bold text-[var(--ocean-dark)] mb-6">История метрик</h2>
        
        <% if (metrics.length === 0) { %>
        <p class="text-gray-600 text-lg">Метрики ещё не добавлялись</p>
        <% } else { %>
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead class="bg-[var(--ocean-blue)] text-white">
                    <tr>
                        <th class="p-4 text-left text-xl">Дата</th>
                        <th class="p-4 text-left text-xl">Самост.</th>
                        <th class="p-4 text-left text-xl">Мышление</th>
                        <th class="p-4 text-left text-xl">Результат</th>
                        <th class="p-4 text-left text-xl">Комментарий</th>
                    </tr>
                </thead>
                <tbody>
                    <% metrics.forEach(metric => { %>
                    <tr class="border-b hover:bg-gray-50">
                        <td class="p-4 text-large"><%= new Date(metric.created_at).toLocaleDateString('ru-RU') %></td>
                        <td class="p-4 text-large font-semibold text-[var(--ocean-blue)]"><%= metric.independence_score %>%</td>
                        <td class="p-4 text-large font-semibold text-[var(--turquoise)]"><%= metric.thinking_depth_score %>%</td>
                        <td class="p-4 text-large font-semibold text-green-600"><%= metric.completion_rate %>%</td>
                        <td class="p-4 text-large"><%= metric.notes || '-' %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } %>
    </div>
</div>
