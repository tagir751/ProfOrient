<%- include('../layout', {title: 'Дашборд администратора'}) %>

<div class="max-w-7xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-[var(--ocean-dark)] mb-8">Панель администратора</h1>
    
    <!-- Статистика -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Учеников</p>
                    <p class="text-5xl font-bold text-[var(--ocean-blue)]"><%= studentsCount %></p>
                </div>
                <div class="text-6xl">👨‍🎓</div>
            </div>
        </div>
        
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Наставников</p>
                    <p class="text-5xl font-bold text-[var(--turquoise)]"><%= mentorsCount %></p>
                </div>
                <div class="text-6xl">👩‍🏫</div>
            </div>
        </div>
        
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Проектов</p>
                    <p class="text-5xl font-bold text-green-600"><%= projectsCount %></p>
                </div>
                <div class="text-6xl">📁</div>
            </div>
        </div>
        
        <div class="glass-panel p-6 card-hover">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-gray-600 text-lg mb-2">Сессий</p>
                    <p class="text-5xl font-bold text-purple-600"><%= sessionsCount %></p>
                </div>
                <div class="text-6xl">💬</div>
            </div>
        </div>
    </div>
    
    <!-- Быстрые действия -->
    <div class="glass-panel p-6 mb-8">
        <h2 class="text-3xl font-bold text-[var(--ocean-dark)] mb-6">Быстрые действия</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <a href="/admin/users/create" class="btn-ocean px-6 py-4 rounded-lg text-xl text-center font-semibold">
                ➕ Добавить пользователя
            </a>
            <a href="/admin/users" class="btn-ocean px-6 py-4 rounded-lg text-xl text-center font-semibold">
                👥 Управление пользователями
            </a>
            <a href="/api/export/all" class="btn-ocean px-6 py-4 rounded-lg text-xl text-center font-semibold">
                📊 Экспорт всех данных (Excel)
            </a>
        </div>
    </div>
    
    <!-- Импорт/Экспорт базы -->
    <div class="glass-panel p-6">
        <h2 class="text-3xl font-bold text-[var(--ocean-dark)] mb-6">Резервное копирование</h2>
        <div class="space-y-4">
            <div class="flex flex-col md:flex-row gap-4 items-center">
                <form action="/api/import" method="POST" enctype="multipart/form-data" class="flex-1 w-full">
                    <label class="block text-xl font-semibold text-gray-700 mb-2">Загрузить базу из Excel:</label>
                    <div class="flex gap-4">
                        <input 
                            type="file" 
                            name="file" 
                            accept=".xlsx,.xls" 
                            required
                            class="flex-1 input-large border-2 border-gray-300 rounded-lg p-4"
                        >
                        <button type="submit" class="btn-ocean px-8 py-4 rounded-lg text-xl font-semibold">
                            Загрузить
                        </button>
                    </div>
                    <p class="text-gray-600 mt-2 text-lg">⚠️ После загрузки вы увидите предпросмотр данных перед подтверждением импорта</p>
                </form>
            </div>
        </div>
    </div>
</div>
