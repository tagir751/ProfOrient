<%- include('../layout', {title: action === 'create' ? 'Добавить пользователя' : 'Редактировать пользователя'}) %>

<div class="max-w-3xl mx-auto p-6">
    <div class="glass-panel p-8">
        <h1 class="text-4xl font-bold text-[var(--ocean-dark)] mb-8">
            <%= action === 'create' ? '➕ Добавить пользователя' : '✏️ Редактировать пользователя' %>
        </h1>
        
        <form 
            action="<%= action === 'create' ? '/admin/users' : '/admin/users/' + user.id %>" 
            method="POST"
            <% if (action === 'edit') { %>data-method="put"<% } %>
            class="space-y-6"
        >
            <% if (action === 'edit') { %>
            <input type="hidden" name="_method" value="PUT">
            <% } %>
            
            <div>
                <label for="login" class="block text-2xl font-semibold text-gray-700 mb-2">Логин *</label>
                <input 
                    type="text" 
                    id="login" 
                    name="login" 
                    value="<%= user ? user.login : '' %>"
                    required
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                >
            </div>
            
            <div>
                <label for="password" class="block text-2xl font-semibold text-gray-700 mb-2">
                    Пароль <%= action === 'edit' ? '(оставьте пустым, чтобы не менять)' : '*' %>
                </label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    <%= action === 'create' ? 'required' : '' %>
                    minlength="4"
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                    placeholder="Минимум 4 символа, буквы и цифры"
                >
                <% if (action === 'edit') { %>
                <p class="text-gray-600 mt-2 text-lg">⚠️ Введите новый пароль только если хотите его изменить</p>
                <% } %>
            </div>
            
            <div>
                <label for="full_name" class="block text-2xl font-semibold text-gray-700 mb-2">Полное имя</label>
                <input 
                    type="text" 
                    id="full_name" 
                    name="full_name" 
                    value="<%= user ? user.full_name || '' : '' %>"
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                >
            </div>
            
            <div>
                <label for="role" class="block text-2xl font-semibold text-gray-700 mb-2">Роль *</label>
                <select 
                    id="role" 
                    name="role" 
                    required
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                >
                    <option value="student" <%= user && user.role === 'student' ? 'selected' : '' %>>Ученик</option>
                    <option value="mentor" <%= user && user.role === 'mentor' ? 'selected' : '' %>>Наставник</option>
                    <option value="admin" <%= user && user.role === 'admin' ? 'selected' : '' %>>Администратор</option>
                </select>
            </div>
            
            <div id="mentorField" style="display: <%= user && user.role === 'student' ? 'block' : 'none' %>">
                <label for="mentor_id" class="block text-2xl font-semibold text-gray-700 mb-2">Наставник</label>
                <select 
                    id="mentor_id" 
                    name="mentor_id" 
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                >
                    <option value="">Без наставника</option>
                    <% mentors.forEach(mentor => { %>
                    <option value="<%= mentor.id %>" <%= user && user.mentor_id === mentor.id ? 'selected' : '' %>><%= mentor.full_name || mentor.login %></option>
                    <% }) %>
                </select>
            </div>
            
            <div class="flex gap-4 pt-6">
                <button 
                    type="submit" 
                    class="btn-ocean flex-1 py-4 rounded-lg text-xl font-semibold"
                >
                    <%= action === 'create' ? 'Создать' : 'Сохранить' %>
                </button>
                <a 
                    href="/admin/users" 
                    class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-8 py-4 rounded-lg text-xl font-semibold text-center"
                >
                    Отмена
                </a>
            </div>
        </form>
    </div>
</div>

<script>
// Показываем поле выбора наставника только для учеников
document.getElementById('role').addEventListener('change', function() {
    const mentorField = document.getElementById('mentorField');
    if (this.value === 'student') {
        mentorField.style.display = 'block';
    } else {
        mentorField.style.display = 'none';
    }
});
</script>
