<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ошибка - mTracker</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: linear-gradient(135deg, #f0f8ff 0%, #87ceeb 50%, #40e0d0 100%);
            min-height: 100vh;
        }
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 12px 48px rgba(0, 105, 148, 0.25);
        }
    </style>
</head>
<body class="flex items-center justify-center p-4">
    <div class="glass-panel p-8 w-full max-w-md text-center">
        <h1 class="text-4xl font-bold text-red-600 mb-4">Ошибка</h1>
        <p class="text-xl text-gray-700 mb-6"><%= message %></p>
        <a href="/" class="bg-blue-500 hover:bg-blue-600 text-white px-6 py-3 rounded-lg text-lg transition">На главную</a>
    </div>
</body>
</html>
