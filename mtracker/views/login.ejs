<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вход - mTracker</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --ocean-dark: #006994;
            --ocean-blue: #0077be;
            --turquoise: #40e0d0;
            --sky-blue: #87ceeb;
            --cloud-white: #f0f8ff;
        }
        
        body {
            background: linear-gradient(135deg, var(--cloud-white) 0%, var(--sky-blue) 50%, var(--turquoise) 100%);
            min-height: 100vh;
        }
        
        .glass-panel {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            box-shadow: 0 12px 48px rgba(0, 105, 148, 0.25);
            border: 1px solid rgba(255, 255, 255, 0.4);
        }
        
        .btn-ocean {
            background: linear-gradient(135deg, var(--ocean-blue), var(--turquoise));
            color: white;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(0, 119, 190, 0.3);
        }
        
        .btn-ocean:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 119, 190, 0.4);
        }
        
        .input-large {
            font-size: 1.2rem;
            padding: 1rem 1.25rem;
        }
    </style>
</head>
<body class="flex items-center justify-center p-4">
    <div class="glass-panel p-8 w-full max-w-md">
        <div class="text-center mb-8">
            <img src="/images/logo.png" alt="mTracker Logo" class="h-24 w-auto mx-auto mb-4">
            <h1 class="text-4xl font-bold text-[var(--ocean-dark)] mb-2">mTracker</h1>
            <p class="text-xl text-gray-600">Система трекинга прогресса</p>
        </div>
        
        <% if (error) { %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg mb-6 text-lg">
            <%= error %>
        </div>
        <% } %>
        
        <form action="/login" method="POST" class="space-y-6">
            <div>
                <label for="login" class="block text-xl font-semibold text-gray-700 mb-2">Логин</label>
                <input 
                    type="text" 
                    id="login" 
                    name="login" 
                    required
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                    placeholder="Введите ваш логин"
                >
            </div>
            
            <div>
                <label for="password" class="block text-xl font-semibold text-gray-700 mb-2">Пароль</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    required
                    class="input-large w-full border-2 border-gray-300 rounded-lg focus:border-[var(--ocean-blue)] focus:ring-2 focus:ring-[var(--sky-blue)] outline-none transition"
                    placeholder="Введите ваш пароль"
                >
            </div>
            
            <button 
                type="submit" 
                class="btn-ocean w-full py-4 rounded-lg text-xl font-semibold"
            >
                Войти
            </button>
        </form>
        
        <div class="mt-6 text-center text-gray-600 text-lg">
            <p>Первый вход? Обратитесь к администратору</p>
        </div>
    </div>
</body>
</html>
