<%- include('../layout', {title: 'Мои действия'}) %>

<div class="max-w-5xl mx-auto p-6">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-4xl font-bold text-[var(--ocean-dark)]">Мои действия</h1>
        <button onclick="openModal('actionModal')" class="btn-ocean px-8 py-4 rounded-lg text-xl font-semibold">➕ Добавить действие</button>
    </div>
    
    <div class="glass-panel overflow-hidden">
        <% if (actions.length === 0) { %>
        <p class="p-8 text-center text-gray-600 text-xl">Нет действий. Добавьте первое!</p>
        <% } else { %>
        <table class="w-full">
            <thead class="bg-[var(--ocean-blue)] text-white">
                <tr><th class="p-4 text-left text-xl">Описание</th><th class="p-4 text-left text-xl">Статус</th><th class="p-4 text-left text-xl">Приоритет</th><th class="p-4 text-left text-xl">Срок</th></tr>
            </thead>
            <tbody>
                <% actions.forEach(a => { %>
                <tr class="border-b hover:bg-gray-50">
                    <td class="p-4 text-large"><%= a.description %></td>
                    <td class="p-4"><span class="px-3 py-1 rounded-full text-sm font-semibold <%= a.status === 'completed' ? 'bg-green-100 text-green-700' : a.status === 'in_progress' ? 'bg-blue-100 text-blue-700' : a.status === 'cancelled' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700' %>"><%= a.status === 'completed' ? '✓ Готово' : a.status === 'in_progress' ? 'В работе' : a.status === 'cancelled' ? 'Отменено' : 'Ожидает' %></span></td>
                    <td class="p-4 text-large"><%= a.priority === 'high' ? '🔴 Высокий' : a.priority === 'medium' ? '🟡 Средний' : '🟢 Низкий' %></td>
                    <td class="p-4 text-large"><%= a.due_date ? new Date(a.due_date).toLocaleDateString('ru-RU') : '-' %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
        <% } %>
    </div>
</div>

<div id="actionModal" class="modal-overlay hidden">
    <div class="glass-panel p-8 max-w-2xl w-full modal-content">
        <h2 class="text-3xl font-bold text-[var(--ocean-dark)] mb-6">Добавить действие</h2>
        <form action="/student/actions" method="POST" class="space-y-4">
            <div><label class="block text-xl font-semibold text-gray-700 mb-2">Описание *</label><input type="text" name="description" required class="input-large w-full border-2 border-gray-300 rounded-lg p-4"></div>
            <div><label class="block text-xl font-semibold text-gray-700 mb-2">Статус</label><select name="status" class="input-large w-full border-2 border-gray-300 rounded-lg p-4"><option value="pending">Ожидает</option><option value="in_progress">В работе</option><option value="completed">Готово</option><option value="cancelled">Отменено</option></select></div>
            <div><label class="block text-xl font-semibold text-gray-700 mb-2">Приоритет</label><select name="priority" class="input-large w-full border-2 border-gray-300 rounded-lg p-4"><option value="low">Низкий</option><option value="medium" selected>Средний</option><option value="high">Высокий</option></select></div>
            <div><label class="block text-xl font-semibold text-gray-700 mb-2">Срок выполнения</label><input type="date" name="due_date" class="input-large w-full border-2 border-gray-300 rounded-lg p-4"></div>
            <div class="flex gap-4"><button type="submit" class="btn-ocean flex-1 py-4 rounded-lg text-xl font-semibold">Сохранить</button><button type="button" onclick="closeModal('actionModal')" class="bg-gray-300 hover:bg-gray-400 text-gray-800 px-6 py-4 rounded-lg text-xl font-semibold">Отмена</button></div>
        </form>
    </div>
</div>
