<%- include('../layout', {title: project.name}) %>
<div class="max-w-5xl mx-auto p-6">
    <h1 class="text-4xl font-bold text-[var(--ocean-dark)] mb-4"><%= project.name %></h1>
    <p class="text-xl text-gray-600 mb-6"><%= project.description || 'Без описания' %></p>
    <h2 class="text-2xl font-bold mb-4">Участники:</h2>
    <ul class="mb-6"><% members.forEach(m => { %><li class="text-large"><%= m.full_name || m.login %></li><% }) %></ul>
    <h2 class="text-2xl font-bold mb-4">Действия:</h2>
    <% if (actions.length === 0) { %><p class="text-gray-600">Нет действий</p><% } else { %>
    <ul><% actions.forEach(a => { %><li class="text-large border-b py-2"><%= a.description %> - <%= a.status %></li><% }) %></ul>
    <% } %>
</div>
