<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8"><title>Карточка ученика - <%= student.full_name || student.login %></title>
    <style>
        body{font-family:Arial,sans-serif;padding:40px;background:#f0f8ff}
        .card{max-width:900px;margin:0 auto;background:white;padding:30px;border-radius:16px;box-shadow:0 4px 20px rgba(0,0,0,0.1)}
        h1{color:#006994;border-bottom:3px solid #40e0d0;padding-bottom:10px}
        h2{color:#0077be;margin-top:30px}
        table{width:100%;border-collapse:collapse;margin:15px 0}
        th,td{border:1px solid #ddd;padding:10px;text-align:left}
        th{background:#0077be;color:white}
        .metric{display:inline-block;margin:10px;padding:15px;background:#e0f7fa;border-radius:8px}
        @media print{body{background:white}.card{box-shadow:none}}
    </style>
</head>
<body>
    <div class="card">
        <img src="/images/logo.png" alt="Logo" style="height:60px;margin-bottom:20px">
        <h1><%= student.full_name || student.login %></h1>
        <p><strong>Логин:</strong> <%= student.login %></p>
        
        <h2>📊 Метрики (динамика)</h2>
        <% if (metrics.length > 0) { %>
        <div><% metrics.forEach(m => { %>
            <div class="metric">
                <strong><%= new Date(m.created_at).toLocaleDateString('ru-RU') %></strong><br>
                Самост.: <%= m.independence_score %>% | Мышление: <%= m.thinking_depth_score %>% | Результат: <%= m.completion_rate %>%
            </div>
        <% }) %></div>
        <% } else { %><p>Нет метрик</p><% } %>
        
        <h2>💬 Сессии</h2>
        <table><thead><tr><th>Дата</th><th>Тема</th><th>Заметки</th></tr></thead><tbody>
        <% sessions.forEach(s => { %><tr><td><%= new Date(s.session_date).toLocaleDateString('ru-RU') %></td><td><%= s.topic || '-' %></td><td><%= s.notes || '-' %></td></tr><% }) %>
        </tbody></table>
        
        <h2>✅ Действия</h2>
        <table><thead><tr><th>Описание</th><th>Статус</th><th>Приоритет</th></tr></thead><tbody>
        <% actions.forEach(a => { %><tr><td><%= a.description %></td><td><%= a.status %></td><td><%= a.priority %></td></tr><% }) %>
        </tbody></table>
        
        <h2>📁 Проекты</h2>
        <table><thead><tr><th>Название</th><th>Описание</th></tr></thead><tbody>
        <% projects.forEach(p => { %><tr><td><%= p.name %></td><td><%= p.description || '-' %></td></tr><% }) %>
        </tbody></table>
    </div>
    <script>window.onload=function(){window.print()}</script>
</body>
</html>
